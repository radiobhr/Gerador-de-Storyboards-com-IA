rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: Default deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Storyboards sub-rules and validators
    match /storyboards/{storyboardId} {
      
      // Prevent id poisoning on targets
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isEmailVerified() 
                    && request.resource.data.userId == request.auth.uid
                    && isValidStoryboard(request.resource.data);
                    
      allow update: if isEmailVerified()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.id == resource.data.id
                    && isValidStoryboard(request.resource.data)
                    && request.resource.data.diff(resource.data).affectedKeys().hasAny(['scenes', 'videoUrl', 'title', 'concept', 'style', 'language', 'timestamp']);
                    
      allow delete: if isEmailVerified() && resource.data.userId == request.auth.uid;
    }

    // Validation blueprints for individual entities
    function isValidStoryboard(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'concept', 'type', 'style', 'language', 'timestamp', 'scenes'])
        && data.keys().size() >= 9
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.concept is string && data.concept.size() <= 10000
        && data.type is string && data.type.size() <= 50
        && data.style is string && data.style.size() <= 100
        && data.language is string && data.language.size() <= 100
        && data.timestamp is number && data.timestamp > 0
        && data.scenes is list && data.scenes.size() <= 100
        && (data.scenes.size() == 0 || data.scenes[0] is map)
        && (!('videoUrl' in data) || (data.videoUrl is string && data.videoUrl.size() <= 2000));
    }
  }
}
